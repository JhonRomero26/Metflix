---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Metflix" description="Encuentra peliculas en un solo lugar">
  <link slot="head" rel="shortcut icon" href="/assets/img/favicon.png" type="image/x-icon">
  <link slot="head" type="text/css" rel="stylesheet" href="/assets/css/style.css" />
  <link slot="head" type="text/css" rel="stylesheet" href="/assets/css/modal.css" />
  <script slot="head" src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.13.0/js/all.min.js"></script>

  <section class="search-content"
    style="background-image: url('https://www.altonivel.com.mx/wp-content/uploads/2019/12/ford-ferrari-1.jpg');">
    <h2 class="subtitle">Qué quieres ver hoy?</h2>
    <form action="" id="form">
      <input id="search-box" name="movie" class="form-search" type="search" placeholder="Buscar...">
    </form>
    <section class="new-recharge-buton">
      <button class="modal-btn primary" onclick="newRecharge()">Recargar peliculas</button>
    </section>
  </section>
  
  <section class="is-hide" id="results-container">
    <h3 class="carousel-title">Tus Resultados</h3>
    <div class="carousel-videos">
      <div class="carousel-body">
  
      </div>
  </section>
  
  <section id="rating-container">
    <h3 class="carousel-title">Mas Populares</h3>
    <div class="carousel-videos">
      <div class="carousel-body">
  
      </div>
  </section>
  <section id="animation-container">
    <h3 class="carousel-title">Animation</h3>
    <div class="carousel-videos">
      <div class="carousel-body">
  
      </div>
  </section>
  <section id="action-container">
    <h3 class="carousel-title">Action</h3>
    <div class="carousel-videos">
      <div class="carousel-body">
  
      </div>
  </section>
  <section id="drama-container">
    <h3 class="carousel-title">Drama</h3>
    <div class="carousel-videos">
      <div class="carousel-body">
      </div>
  </section>
  
  
  
  <!-- <script type="module" src="/assets/js/cardMovieGenerator.js"></script> -->
  <script is:inline src="/assets/js/index.js"></script>
</Layout>
